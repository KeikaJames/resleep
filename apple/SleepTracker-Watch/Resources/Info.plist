<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key><string>Circadia</string>
  <key>CFBundleName</key><string>$(PRODUCT_NAME)</string>
  <key>CFBundleExecutable</key><string>$(EXECUTABLE_NAME)</string>
  <key>CFBundlePackageType</key><string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
  <key>CFBundleIdentifier</key><string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleShortVersionString</key><string>$(MARKETING_VERSION)</string>
  <key>CFBundleVersion</key><string>$(CURRENT_PROJECT_VERSION)</string>
  <key>CFBundleDevelopmentRegion</key><string>en</string>
  <key>CFBundleLocalizations</key>
  <array>
    <string>en</string>
    <string>zh-Hans</string>
  </array>
  <key>ITSAppUsesNonExemptEncryption</key><false/>
  <key>WKApplication</key><true/>
  <key>WKCompanionAppBundleIdentifier</key><string>$(BASE_BUNDLE_ID).ios</string>
  <key>WKRunsIndependentlyOfCompanionApp</key><true/>
  <key>WKBackgroundModes</key>
  <array><string>workout-processing</string></array>
  <key>NSHealthShareUsageDescription</key>
  <string>Sleep reads heart rate on-device during workouts to detect sleep stages.</string>
  <key>NSHealthUpdateUsageDescription</key>
  <string>Sleep can optionally write sleep analysis back to HealthKit.</string>
  <key>NSMotionUsageDescription</key>
  <string>Sleep uses motion to detect restlessness overnight.</string>
</dict>
</plist>
