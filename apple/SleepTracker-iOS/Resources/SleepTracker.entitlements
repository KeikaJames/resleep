<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>com.apple.developer.healthkit</key>
  <true/>
  <!--
    Required to load the on-device LLM weights without iOS jetsam
    SIGKILL. The Circadia AI tier ships ~2 GB of 4-bit weights that
    are mmap'd by MLX; together with Metal cache + KV cache + the
    Swift runtime + UI this exceeds the default ~3 GB budget on
    most iPhones. This entitlement is documented and free to use
    on iOS 15+; App Review allows it as long as the elevated memory
    is genuinely needed by an on-device ML feature, which it is.
  -->
  <key>com.apple.developer.kernel.increased-memory-limit</key>
  <true/>
</dict>
</plist>
