<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key><string>Circadia</string>
  <key>CFBundleName</key><string>$(PRODUCT_NAME)</string>
  <key>CFBundleExecutable</key><string>$(EXECUTABLE_NAME)</string>
  <key>CFBundlePackageType</key><string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
  <key>CFBundleIdentifier</key><string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleShortVersionString</key><string>$(MARKETING_VERSION)</string>
  <key>CFBundleVersion</key><string>$(CURRENT_PROJECT_VERSION)</string>
  <key>CFBundleDevelopmentRegion</key><string>en</string>
  <key>CFBundleLocalizations</key>
  <array>
    <string>en</string>
    <string>zh-Hans</string>
  </array>
  <key>ITSAppUsesNonExemptEncryption</key><false/>
  <key>LSRequiresIPhoneOS</key><true/>
  <key>UILaunchScreen</key><dict/>
  <key>UIRequiredDeviceCapabilities</key>
  <array><string>arm64</string></array>
  <key>NSHealthShareUsageDescription</key>
  <string>Circadia reads heart rate and HRV locally on-device to classify sleep stages. Data never leaves your device.</string>
  <key>NSHealthUpdateUsageDescription</key>
  <string>Circadia can optionally write sleep analysis back to HealthKit.</string>
  <key>NSMicrophoneUsageDescription</key>
  <string>If enabled, Circadia listens for breathing events on-device. Audio is never uploaded or saved.</string>
  <key>NSMotionUsageDescription</key>
  <string>Circadia uses motion to detect restlessness while you sleep.</string>
  <key>UIBackgroundModes</key>
  <array>
    <string>audio</string>
  </array>
</dict>
</plist>
